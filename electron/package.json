{
  "name": "bonsai-ide",
  "version": "0.1.0",
  "description": "BonsAI IDE — local AI coding desktop client",
  "author": "Trooper3001",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "dev.bonsai.ide",
    "productName": "BonsAI IDE",
    "files": ["main.js", "loading.html"],
    "extraResources": [
      { "from": "../server.py",       "to": "backend/server.py" },
      { "from": "../bonsai_engine.py","to": "backend/bonsai_engine.py" },
      { "from": "../frontend",        "to": "backend/frontend" }
    ],
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    },
    "win": { "target": ["nsis"] },
    "mac": { "target": ["dmg"] }
  }
}
